/* :.config/rofi/config.rasi
*/
configuration {{
    theme: "rofi-theme.rasi";
    modi: "window,run,drun";
    columns: 1;
    show-icons: false;
    icon-theme: "{icons}";
    location: 0;
    hide-scrollbar: true;
    font: "{font0} {font-size}";
    disable-history: false;
    window-format: " {{w}}   {{c}}   {{t}}";
}}
