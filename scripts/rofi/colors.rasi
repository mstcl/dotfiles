/* colors */

* {
    al: #d0d0d0;
    bg: #f5f5f5;
    bg1: #811f34;
    bg2: #4f6c31;
    bg3: #944927;
    bg4: #2b4c5e;
    bg5: #7b5164;
    bg6: #749176;
    fg: #303030;
    fg2: #151515;
    hi-bold: bold #811f34;
    font: "JetBrainsMono Nerd Font 16";
    font-icon: "JetBrainsMono Nerd Font 14";
    icon-theme: "Colloid-grey-light";
    show-icons: true;
}
