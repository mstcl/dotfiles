/* colors */

* {
    al: #d0d0d0;
    bg: #f5f5f5;
    bg1: #ac4142;
    bg2: #90a959;
    bg3: #f4bf75;
    bg4: #6a9fb5;
    bg5: #aa759f;
    bg6: #75b5aa;
    fg: #303030;
    fg2: #151515;
    hi-bold: bold #ac4142;
    font: "JetBrainsMono Nerd Font 16";
    font-icon: "JetBrainsMono Nerd Font 14";
    icon-theme: "Colloid-grey-light";
    show-icons: true;
}
