/* colors */

* {
    al: #3c3836;
    bg: #282828;
    bg1: #b53934;
    bg2: #86852c;
    bg3: #cb952d;
    bg4: #4f7c7e;
    bg5: #a56e87;
    bg6: #749176;
    fg: #d5c4a1;
    fg2: #ebdbb2;
    hi-bold: bold #b53934;
    font: "JetBrainsMono Nerd Font 17";
    font-icon: "JetBrainsMono Nerd Font 14";
    icon-theme: "Gruvbox_Dark-2";
    show-icons: true;
}
