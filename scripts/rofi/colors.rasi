/* colors */

* {
    al: #363636;
    bg: #202020;
    bg1: #6b7f78;
    bg2: #7f6d6b;
    bg3: #7e776a;
    bg4: #686057;
    bg5: #4e575e;
    bg6: #796a80;
    fg: #a19d94;
    fg2: #b2ada3;
    hi-bold: bold #6b7f78;
    font: "JetBrainsMono Nerd Font 17";
    font-icon: "JetBrainsMono Nerd Font 14";
    icon-theme: "Fluent-grey-dark";
    show-icons: true;
}
