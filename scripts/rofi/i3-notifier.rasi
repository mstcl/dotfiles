configuration {
    columns: 1;
    eh: 2;
    kb-accept-entry: "Control+j,Control+m,Return,KP_Enter,space";
    kb-custom-1: "Delete,d";
    kb-remove-char-forward: "";
    kb-row-down: "Down,Control+n,j";
    kb-row-up: "Up,Control+p,k";
    me-accept-entry: "MousePrimary";
    me-select-entry: "";
    show-icons: true;
    font: "JetBrainsMono Nerd Font Mono 12";
    icon-theme: "Fluent-grey-dark";
    background-color: @bg;

}
@import "~/scripts/rofi/colors.rasi"
* {
    background-color: rgba(0,0,0,0);
    border-radius: 2px;
    text-color: @fg;
}

#window {
    height: 30%;
    width: 20em;
    text-color: @fg;
    children: [inputbar,listview];
    border-radius: 2px;
    background-color: @bg;
    text-color: @fg;
}

#listview {
    dynamic: false;
    padding: 10px;
    lines: 0;
    spacing: 10px;
    background-color: @bg;
    text-color: @fg;
}

#element {
    padding: 10px;
    border-radius: 2px;
    background-color: @bg;
    text-color: @al;
}

#element.active {
    background-color: @bg;
    text-color: @al;
}

#element.urgent {
    background-color: @bg;
    text-color: @bg3;
}

#element.selected {
    background-color: @al;
    text-color: @fg;
}

#element.selected.active {
    background-color: @al;
    text-color: @fg;
}

#element.selected.urgent {
    background-color: @al;
    text-color: @bg3;
}

#element-icon {
    background-color: inherit;
    text-color: inherit;
    size: 0em;
    horizontal-align: 0;
    vertical-align: 0;
    padding: 0 0 0 0;
    border-radius: 2px;
}

#inputbar {
    children: [textbox-prompt-colon];
    background-color: @fg;
    text-color: @fg;
    expand: false;
    border: 0px;
    spacing: 0px;
}

#textbox-prompt-colon {
    expand: false;
    str: "Notifications";
    font: "JetBrainsMono Nerd Font Mono 12";
    padding: 9px 3px 8px 18px;
    background-color: @fg;
    text-color: @bg;
}
