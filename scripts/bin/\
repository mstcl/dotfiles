#!/usr/bin/env bash

set -o errexit -o noclobber -o nounset

green=144119ff
pink=b24d7aff
red=682828ff
cyan=1d0e53ff
transparent=00000000
slighttransparent=630e49ff
semitrans=fff7e9ff
timecolor=000000ff

screenH=$(xrandr --current | grep '*' | uniq | awk '{print $1}' | cut -d 'x' -f2 | head -n 1)
timeposx=50
timeposy=$((screenH-100))
dateposy=$((timeposy+50))

i3lock-fancy-rapid 5 pixel \
    --screen=1 \
    --indicator \
    --bar-indicator --bar-color=$slighttransparent --bar-direction=0 \
    --bar-orientation=vertical --bar-pos="x:y" --bar-base-width=44 \
    --verif-text=" " --wrong-text=" " \
    --lockfailed-text=" " --lock-text=" " --noinput-text=" " \
    --wrong-color=$red \
    --clock --time-str="%H:%M" \
    --time-align=1 --time-size=72 --time-pos="x+$timeposx:y+$timeposy"\
    --time-font=serif \
    --date-str="%a, %b %d" --date-align=1 --date-size=34 \
    --date-font=serif --date-pos="x+$timeposx:y+$dateposy" \
