# :.config/sxhkd/sxhkdrc
# vim:set ft=sxhkd:

##############
#  KEYBINDS  #
##############

# a:         wmfocus               | shift a:         signal
# b:         librewolf             | shift b:         chromium
# c:         colorpicker           | shift c:         lock
# d:         powermenu             | shift d:         discord
# e:         nemo                  |
# f:         fullscreen toggle     | shift f:         logseq
# g:         text scratchpad       |
# h:         focus left            | shift h:         move left
# i:         zathura               | shift i:         change input
# j:         focus down            | shift j:         move down
# k:         focus up              | shift k:         move up
# l:         focus right           | shift l:         move right
# m:         MONITOR CHORDS--------| shift m:         mute
#            i : gaming            |
#            o : non-gaming        |
# n:         trdop                 | shift n:         mute mic
# o:         sticky toggle         | shift o:         move to DP-4
# p:         SCREENSHOT CHORDS-----|
#            r : region & gui      |
#            f : fullscreen        |
# q:         qalculate             | shift q:         quit window
# r:         RESTART CHORDS--------|
#            w : i3                |
#            s : sxhkd             |
#            p : polybar           |
#            c : wpg theme         |
# s:         sonixd                | shift s:         steam
# t:         toggle dunst          |
# u:         monitor               |
# v:         SET GAPS              |
#            i : gaps on           |
#            o : gaps off          |
# w:         status notification   |
# x:         toggle layout         | shift x:         rnote
# y:         select sink           |
# z:         toggle focus          |
# \:         last workspace        |
# .:         next track            | shift .:         volume up
# ,:         previous track        | shift ,:         volume down
# /:         play/pause            | shift /:         keys help
# -:         move to scratchpad    |
# =:         toggle scratchpad     |
# return:    terminal              | shift return:    nvim
# tab:       current windows       |
# space:     launcher              | shift space:     float toggle
# {1-0}:     workspaces 1-10       | shift {1-0}:     move to wsp 1-10
# alt {1-0}: workspaces 1-10       | shift alt {1-0}: move to wsp 11-20
# escape:    dunst history         |
# backspace: dunst close           | shift backspace: close all
# left:      focus wsp left        | shift left:      move to wsp left
# right:     focus wsp right       | shift right:     move to wsp right

super + a
	focus

super + shift + a
	signal-desktop-beta --disable-frame-rate-limit

super + b
	librewolf
	# vivaldi-snapshot --disk-cache-dir="$XDG_RUNTIME_DIR/vivaldi-cache" --process-per-site --ignore-gpu-blocklist --enable-gpu-rasterization --enable-zero-copy --disable-gpu-driver-bug-workarounds --enable-native-gpu-memory-buffers
	# GTK_THEME=cdetheme-solaris librewolf

super + shift + b
	thorium-browser

super + c
	colorpicker

super + shift + c
	lockscreen

super + d
	power-menu

super + shift + d
	/usr/bin/discord --disable-frame-rate-limit --class=discord --enable-gpu-rasterization --use-gl=desktop --enable-zero-copy --ignore-gpu-blocklist

super + e
	wezterm --config-file "/home/lckdscl/dotfiles/.config/wezterm/wezterm-nvim.lua" start --class "float" -e "joshuto"

super + shift + e
	nemo

super + {f,o,z}
	i3-msg {fullscreen toggle, sticky toggle, focus mode_toggle}

super + shift + f
	logseq --disable-frame-rate-limit

super + g
   scratchpad

super + {h,j,k,l}
	i3-msg focus {left,down,up,right}

super + shift + {h,j,k,l}
	i3-msg move {left,down,up,right}

super + i
	zathura

super + shift + i
	chkm

super + shift + o
	i3-msg move container to output left

super + n
	wezquake

super + p; {r,f}
	flameshot {gui, full}

super + q
	qalculate-gtk

super + shift + q
	i3-msg kill

super + m; {i,o}
	{game-enter, \
	game-exit}

super + shift + m
	NO_NOTIFY_COLOR=1 i3-volume -nyPp mute

super + shift + n
	pactl set-source-mute @DEFAULT_SOURCE@ toggle

super + r; {c,w,s}
	{wpg -s $(wpg -c) && sleep 0.5 && notify-send -t 1800 "wpgtk" "Theme reloaded", \
	i3-msg restart && sleep 0.5 && notify-send -t 1800 "i3wm" "Window manager reloaded", \
	pkill -USR1 -x sxhkd && sleep 0.5 && notify-send -t 1800 "sxhkd" "Configuration reloaded"}

super + s
	sonixd

super + shift + s;
	steam

super + t
	dunstctl set-paused toggle

super + u
	monitor

super + v; {i,o}
	i3-msg gaps inner all {set 8, set 0}

super + w
	notify-send --icon="none" "❮❮ STATUS  ❯❯" "$(notify)"

super + x
	i3-msg layout toggle stacking splitv splith tabbed

super + shift + x
	rnote

super + y
	select-sink

super + comma
	playerctl -p spotify,mpd,Sonixd previous

super + shift + comma
	NO_NOTIFY_COLOR=1 i3-volume -nyP down 5

super + period
	playerctl -p spotify,mpd,Sonixd next

super + shift + period
	NO_NOTIFY_COLOR=1 i3-volume -nyP up 5

super + slash
	playerctl -p spotify,mpd,Sonixd play-pause

super + shift + slash
	keys

super + space
	rlaunch-default

super + shift + space
	i3-msg floating toggle

super + Return
	wezterm

super + shift + Return
	nv-launch

super + {minus,equal}
	i3-msg { move scratchpad, \
	scratchpad show }

super + {1,2,3,4,5,6,7,8,9}
	i3-msg workspace {1:A,2:B,3:C,4:D,5:E,6:F,7:G,8:H,9:I,0:J} && current-workspace "Currently on workspace"

super + shift + {1,2,3,4,5,6,7,8,9,0}
	i3-msg move container to workspace {1:A,2:B,3:C,4:D,5:E,6:F,7:G,8:H,9:I,0:J}

super + alt + {1,2,3,4,5,6,7,8,9,0}
	i3-msg workspace {11:A,12:B,13:C,14:D,15:E,16:F,17:G,18:H,19:I,20:J} && current-workspace "Currently on workspace"

super + shift + alt {1,2,3,4,5,6,7,8,9,0}
	i3-msg move container to workspace {11:A,12:B,13:C,14:D,15:E,16:F,17:G,18:H,19:I,20:J} && current-workspace "Currently on workspace"

super + {Left,Right}
	i3-msg workspace {prev,next}

super + shift + {Left,Right}
	i3-msg move container to workspace {prev,next}

super + Tab
	dmenu-window

super + Escape
	dunstctl history-pop

super + BackSpace
	dunstctl close

super + shift + BackSpace
	dunstctl close-all
