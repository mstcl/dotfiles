# :.config/i3/config
# vim:set ft=i3config fdm=marker foldenable:

# GENERAL {{{
# Modifier aliases {{{
set $mod Mod4
set $alt Mod1
set $hyper Mod3
set $monL DP-2
set $monR DP-4

# variables for workpacenames; 
set $ws1L 1:A
set $ws1R 11:A
set $ws2L 2:B
set $ws2R 12:B
set $ws3L 3:C
set $ws3R 13:C
set $ws4L 4:D
set $ws4R 14:D
set $ws5L 5:E
set $ws5R 15:E
set $ws6L 6:F
set $ws6R 16:F
set $ws7L 7:G
set $ws7R 17:G
set $ws8L 8:H
set $ws8R 18:H
set $ws9L 9:I
set $ws9R 19:I
set $ws0L 10:J
set $ws0R 20:J

# assign workspaces to specific outputs
workspace $ws1L output $monL
workspace $ws1R output $monR
workspace $ws2L output $monL
workspace $ws2R output $monR
workspace $ws3L output $monL
workspace $ws3R output $monR
workspace $ws4L output $monL
workspace $ws4R output $monR
workspace $ws5L output $monL
workspace $ws5R output $monR
workspace $ws6L output $monL
workspace $ws6R output $monR
workspace $ws7L output $monL
workspace $ws7R output $monR
workspace $ws8L output $monL
workspace $ws8R output $monR
workspace $ws9L output $monL
workspace $ws9R output $monR
workspace $ws0L output $monL
workspace $ws0R output $monR

# }}}
# Font {{{
font pango:JetBrainsMono Nerd Font Medium 15
# }}}
# Gaps {{{
gaps outer 0
gaps inner 0
smart_gaps on
# }}}
# Polybar gap {{{
# gaps top 0
# }}}
# Borders {{{
smart_borders on
for_window [class="^.*"] border pixel 4
default_border pixel 4
default_floating_border pixel 4
# }}}
# Priority {{{
focus_on_window_activation urgent
popup_during_fullscreen smart
# }}}
# Startup {{{
exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &
# exec --no-startup-id sh $HOME/scripts/bin/wp &
exec --no-startup-id sh $HOME/scripts/bin/norgb &
exec --no-startup-id ibus-daemon -drxR
exec --no-startup-id unclutter &
exec_always --no-startup-id feh --no-fehbg --bg-scale --no-xinerama .cache/superpaper/temp/bim-a.png &
exec_always --no-startup-id autotiling &
# }}}
# From wal {{{
set_from_resource $fg i3wm.color7
set_from_resource $c2 i3wm.color8
set_from_resource $bg i3wm.color0
set_from_resource $c1 i3wm.color1
## class                border  backgr  text indicator child_border
client.focused          $c1     $bg     $fg  $c1       $c1
client.focused_inactive $c2     $bg     $fg  $c2       $c2
client.unfocused        $c2     $bg     $fg  $c2       $c2
client.urgent           $bg     $bg     $fg  $bg       $bg
client.placeholder      $bg     $bg     $fg  $bg       $bg
client.background       $bg
# }}}
# Bare minimum for i3 to work {{{
floating_modifier $mod
bindsym $mod+backslash workspace back_and_forth

# }}}
# }}}
# WINDOW RULES {{{
# Scribus {{{
for_window [class="scribus"] floating enable
# }}}
# MPV {{{
for_window [class="mpv"] floating enable
# }}}
for_window [class="Ds9.tcl"] floating enable
for_window [class="Uget-gtk"] floating enable
# Pavucontrol {{{
for_window [class="Pavucontrol"] floating enable
for_window [class="Pavucontrol"] resize set 940 680
# }}}
# File manager {{{
for_window [class="Pcmanfm"] floating enable
for_window [class="Pcmanfm"] resize set 940 680
for_window [class="Nautilus"] floating enable
for_window [class="Nautilus"] resize set 940 680
for_window [title="Rename File"] resize set 284 164
for_window [title="Execute File"] resize set 284 164
for_window [title="Choose Application"] resize set 284 164
for_window [title="Creating New Folder"] resize set 284 164
for_window [title="Confirm File Replacing"] resize set 284 164
for_window [title="Copying files"] resize set 484 164
for_window [title="Moving files"] resize set 484 164
for_window [title="Deleting files"] resize set 484 164
for_window [class="Nemo"] floating enable
for_window [class="Nemo"] resize set 940 680
# }}}
# Calculator {{{
for_window [class="Qalculate-gtk"] floating enable
for_window [class="Qalculate-gtk"] resize set 640 480
for_window [title="Set Unknowns"] resize set 184 64
# }}}
# matplotlib {{{
for_window [class="^matplotlib$"] floating enable
# }}}
# Terminal {{{
# assign [title="^neovim$"] "11:A"
for_window [class="whole"] fullscreen enable
for_window [class="quake"] floating enable
for_window [class="quake"] border pixel 0
for_window [class="float"] floating enable
for_window [class="float-small"] resize set 640 320
# }}}
# Wpg {{{
for_window [class="Wpg"] floating enable
for_window [class="Wpg"] resize set 640 480
# }}}
# Zoom {{{
for_window [class="zoom"] floating enable
# }}}
# Fileroller {{{
for_window [class="File-roller"] floating enable
# }}}
# Steam {{{
assign [class="^Steam$" title="^Steam$"] "5:E"
for_window [class="^Steam$" title="^Friends List$"] floating enable
for_window [class="^steamwebhelper$" title="^Friends List$"] floating enable
for_window [class="^steamwebhelper$"] floating enable
for_window [class="^Steam$" title="Steam - News"] floating enable
for_window [class="^Steam$" title=".* - Chat"] floating enable
for_window [class="^Steam$" title="^Settings$"] floating enable
for_window [class="^Steam$" title=".* - event started"] floatin enable
for_window [class="^Steam$" title=".* CD key"] floating enable
for_window [class="^Steam$" title="^Steam - Self Updater$"] floating enable
for_window [class="^Steam$" title="^Screenshot Uploader$"] floating enable
for_window [class="^Steam$" title="^Steam Guard - Computer Authorization Required$"] floating enable
for_window [title="^Steam Keyboard$"]  floating enable
for_window [class="steam_app_1182480"] floating enable
# }}}
# Feh {{{
for_window [class="feh"] floating enable
# }}}
# Florence {{{
for_window [class="Florence"] floating enable
# }}}
# Discord {{{
assign [class="^discord$"] "16:F"
assign [class="signal beta"] "16:F"
assign [class="^Guilded$"] "16:F"
# }}}
# }}}
# MODES {{{
# Resize {{{
mode "resize" {
    bindsym j         resize shrink width 10 px or 10 ppt
    bindsym k         resize grow height 10 px or 10 ppt
    bindsym l         resize shrink height 10 px or 10 ppt
    bindsym semicolon resize grow width 10 px or 10 ppt
    bindsym Left      resize shrink width 10 px or 10 ppt
    bindsym Down      resize grow height 10 px or 10 ppt
    bindsym Up        resize shrink height 10 px or 10 ppt
    bindsym Right     resize grow width 10 px or 10 ppt
    bindsym Return    mode "default"
    bindsym Escape    mode "default"
    bindsym $mod+r    mode "default"
}
bindsym $hyper+r        mode "resize"
# }}}
# }}}
