# :.config/i3/config
# vim:set ft=config fdm=marker foldenable:

# GENERAL {{{
# Modifier aliases {{{
set $mod Mod4
set $alt Mod1
set $hyper Mod3
# }}}
# Font {{{
font pango:JetBrainsMono Nerd Font Medium 15
# }}}
# Gaps {{{
gaps outer 0
gaps inner 5
smart_gaps on
# }}}
# Polybar gap {{{
gaps top 0
# }}}
# Borders {{{
smart_borders on
for_window [class="^.*"] border pixel 0
# }}}
# Priority {{{
focus_on_window_activation urgent
popup_during_fullscreen smart
# }}}
# Startup {{{
exec --no-startup-id sxhkd &
exec --no-startup-id aria2c &
exec --no-startup-id bash $HOME/.config/wpg/wp_init.sh &
exec --no-startup-id xss-lock --transfer-sleep-lock -- sh $HOME/scripts/i3lock/lockerfancy.sh &
exec --no-startup-id picom &
exec --no-startup-id xset s off &
exec --no-startup-id ibus-daemon -drxR
exec --no-startup-id unclutter &
# exec --no-startup-id bash $HOME/.config/polybar/launch.sh &
exec --no-startup-id i3-msg 'workspace 1: Term; exec kitty --listen-on unix:/tmp/mykitty'
exec --no-startup-id bash $HOME/scripts/hardware/norgb.sh &
exec_always --no-startup-id sleep 3 && xrdb -load $HOME/.config/X11/Xresources &
exec_always --no-startup-id sleep 4 && xmodmap $HOME/.config/X11/Xmodmap &
exec_always --no-startup-id kitti3 -p tc
exec_always --no-startup-id flashfocus &
exec_always --no-startup-id autotiling &
# }}}
# From wal {{{
set_from_resource $fg i3wm.color7 #f0f0f0
set_from_resource $c2 i3wm.color8 #d0d0d0
set_from_resource $bg i3wm.color0 #f0f0f0
set_from_resource $c1 i3wm.color2 #f0f0f0
## class                border  backgr  text indicator child_border
client.focused          $c2     $bg     $fg  $c2       $c2
client.focused_inactive $bg     $bg     $fg  $bg       $bg
client.unfocused        $bg     $bg     $fg  $bg       $bg
client.urgent           $bg     $bg     $fg  $bg       $bg
client.placeholder      $bg     $bg     $fg  $bg       $bg
client.background       $bg
# }}}
# Bare minimum for i3 to work {{{
floating_modifier $mod
bindsym $mod+backslash workspace back_and_forth
bindsym $mod+n nop kitti3

# }}}
# }}}
# WINDOW RULES {{{
# MPV {{{
for_window [class="mpv"] floating enable
# }}}
for_window [class="Ds9.tcl"] floating enable
for_window [class="Uget-gtk"] floating enable
# Pavucontrol {{{
for_window [class="Pavucontrol"] floating enable
for_window [class="Pavucontrol"] resize set 940 680
# }}}
# File manager {{{
for_window [class="Pcmanfm"] floating enable
for_window [class="Pcmanfm"] resize set 940 680
for_window [class="Nautilus"] floating enable
for_window [class="Nautilus"] resize set 940 680
for_window [title="Rename File"] resize set 284 164
for_window [title="Execute File"] resize set 284 164
for_window [title="Choose Application"] resize set 284 164
for_window [title="Creating New Folder"] resize set 284 164
for_window [title="Confirm File Replacing"] resize set 284 164
for_window [title="Copying files"] resize set 484 164
for_window [title="Moving files"] resize set 484 164
for_window [title="Deleting files"] resize set 484 164
# }}}
# Calculator {{{
for_window [class="Qalculate-gtk"] floating enable
for_window [class="Qalculate-gtk"] resize set 640 480
for_window [title="Set Unknowns"] resize set 184 64
# }}}
# matplotlib {{{
for_window [class="^matplotlib$"] floating enable
# }}}
# Kitty {{{
for_window [class="^kitty$" title="^textScratchpad$"] floating enable
for_window [class="^kitty$" title="^textScratchpad$"] resize set 740 480; move absolute position center
for_window [class="^kitty$" title="^floatingKitty$"] floating enable
for_window [class="^kitty$" title="^floatingKitty$"] resize set 740 480; move absolute position center
for_window [class="^kitty$" title="^cava$"] floating enable
for_window [class="^kitty$" title="^cava$"] resize set 830 320
for_window [class="^kitty$" title="^cava$"] move position 1050 px 100 px
assign [class="^kitty$" title="^cava$"] 4: Media
for_window [class="^kitty$" title="^spotify$"] floating enable
for_window [class="^kitty$" title="^spotify$"] resize set 960 920
for_window [class="^kitty$" title="^spotify$"] move position 45 px 100 px
assign [class="^kitty$" title="^spotify$"] 4: Media
for_window [class="^kitty$" title="^mpd$"] floating enable
for_window [class="^kitty$" title="^mpd$"] resize set 1360 520
assign [class="^kitty$" title="^mpd$"] 4: Media
for_window [class="^kitty$" title="^irc$"] floating enable
for_window [class="^kitty$" title="^irc$"] resize set 1380 875
assign [class="^kitty$" title="^irc$"] 6: Chat
for_window [class="^cover$"] floating enable
for_window [class="^cover$"] move position 1050 px 100 px
assign [class="^cover$"] 4: Media
for_window [class="^kitty$" title="^lyrics$"] floating enable
for_window [class="^kitty$" title="^lyrics$"] resize set 830 575
for_window [class="^kitty$" title="^lyrics$"] move position 1050 px 450 px
assign [class="^kitty$" title="^lyrics$"] 4: Media
# }}}
# Wpg {{{
for_window [class="Wpg"] floating enable
for_window [class="Wpg"] resize set 640 480
# }}}
# Zoom {{{
for_window [class="zoom"] floating enable
# }}}
# Fileroller {{{
for_window [class="File-roller"] floating enable
# }}}
# Steam {{{
assign [class="^Steam$" title="^Steam$"] "5: Games"
for_window [class="^Steam$" title="^Friends List$"] floating enable
for_window [class="^Steam$" title="Steam - News"] floating enable
for_window [class="^Steam$" title=".* - Chat"] floating enable
for_window [class="^Steam$" title="^Settings$"] floating enable
for_window [class="^Steam$" title=".* - event started"] floatin enable
for_window [class="^Steam$" title=".* CD key"] floating enable
for_window [class="^Steam$" title="^Steam - Self Updater$"] floating enable
for_window [class="^Steam$" title="^Screenshot Uploader$"] floating enable
for_window [class="^Steam$" title="^Steam Guard - Computer Authorization Required$"] floating enable
for_window [title="^Steam Keyboard$"]  floating enable
for_window [class="steam_app_1182480"] floating enable
# }}}
# Feh {{{
for_window [class="feh"] floating enable
# }}}
# Florence {{{
for_window [class="Florence"] floating enable
# }}}
# Discord {{{
assign [class="^discord$"] "6: Chat"
for_window [class="^discord$"] floating enable
assign [class="^Guilded$"] "6: Chat"
for_window [class="^Guilded$"] floating enable
# }}}
# }}}
# MODES {{{
# Resize {{{
mode "resize" {
    bindsym j         resize shrink width 10 px or 10 ppt
    bindsym k         resize grow height 10 px or 10 ppt
    bindsym l         resize shrink height 10 px or 10 ppt
    bindsym semicolon resize grow width 10 px or 10 ppt
    bindsym Left      resize shrink width 10 px or 10 ppt
    bindsym Down      resize grow height 10 px or 10 ppt
    bindsym Up        resize shrink height 10 px or 10 ppt
    bindsym Right     resize grow width 10 px or 10 ppt
    bindsym Return    mode "default"
    bindsym Escape    mode "default"
    bindsym $mod+r    mode "default"
}
bindsym $hyper+r        mode "resize"
# }}}
# }}}
