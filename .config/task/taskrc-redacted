# :.config/task/taskrc
# vim:set ft=taskrc:

data.location=~/.local/share/task
include /usr/share/doc/task/rc/dark-16.theme
default.command=next
calendar.legend=yes
calendar.offset=no
calendar.offset.value=-1
verbose=nothing,label,footnote,affected
report.next.columns=id,recur.indicator,due.relative,project,tags,description.count
report.next.labels= ID,R,Due,Project,Tags,Description
color.label=bold white
color.label.sort=bold white
color.alternate=color15 on color8
color.header=yellow
color.footnote=yellow
color.warning=bold red
color.error=white on red
color.debug=blue
color.completed=color8 on black
color.deleted=underline color8 on black
color.active=bold yellow
color.recurring=magenta
color.scheduled=bold green
color.until=black on color8
color.blocked=black on white
color.blocking=black on bright white
color.project.none=
color.uda.priority.H=bold white
color.uda.priority.M=white
color.uda.priority.L=
color.tag.next=
color.tag.none=
color.tagged=
color.due=red
color.due.today=inverse
color.overdue=inverse
#color.uda.X=
color.burndown.done=on green
color.burndown.pending=on red
color.burndown.started=on yellow
color.history.add=black on red
color.history.delete=black on yellow
color.history.done=black on green
color.summary.background=white on black
color.summary.bar=black on green
color.calendar.due=white on red
color.calendar.due.today=bold white on red
color.calendar.holiday=black on bright yellow
color.calendar.overdue=black on bright red
color.calendar.today=bold white on bright blue
color.calendar.weekend=bold white
color.calendar.weeknumber=bold blue
color.sync.added=green
color.sync.changed=yellow
color.sync.rejected=red
color.undo.after=green
color.undo.before=red
taskd.server=freecinc.com:53589
taskd.key=<redacted>
taskd.certificate=<redacted>
taskd.ca=<redacted>
taskd.credentials=<redacted>
news.version=2.6.0
