# :.config/zathura/zathurarc
set font "JetBrainsMono Nerd Font 17"
set synctex true
set selection-notification "true"
set guioptions ""
set adjust-open "best-fit"
set scroll-page-aware "true"
set scroll-full-overlap 0.01
set scroll-step 100
set recolor "true"
set recolor-keephue
set completion-bg "#282828"
set completion-fg "#d5c4a1"
set completion-group-bg "#282828"
set completion-group-fg "#d5c4a1"
set completion-highlight-bg "#282828"
set completion-highlight-fg "#d5c4a1"
set recolor-lightcolor "#282828"
set recolor-darkcolor "#d5c4a1"
set default-bg "#282828"
set inputbar-bg "#3c3836"
set inputbar-fg "#d5c4a1"
set notification-bg "#3c3836"
set notification-fg "#d5c4a1"
set notification-error-bg "#b53934"
set notification-error-fg "#d5c4a1"
set notification-warning-bg "#b53934"
set notification-warning-fg "#d5c4a1"
set statusbar-bg "#3c3836"
set statusbar-fg "#d5c4a1"
set index-bg "#3c3836"
set index-fg "#d5c4a1"
set index-active-bg "#ebdbb2"
set index-active-fg "#282828"
set render-loading-bg "#282828"
set render-loading-fg "#d5c4a1"
set highlight-color "#a2a43d"
set highlight-active-color "#83a598"
set window-title-home-tilde true
set statusbar-basename true
set selection-clipboard clipboard
set scroll-page-aware true
set statusbar-home-tilde true
set statusbar-h-padding 10
set statusbar-v-padding 10
