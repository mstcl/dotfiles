# :.config/zathura/zathurarc
set font "JetBrainsMono Nerd Font 16"
set synctex true
set selection-notification "true"
set guioptions ""
set adjust-open "best-fit"
set scroll-page-aware "true"
set scroll-full-overlap 0.01
set scroll-step 100
set recolor "true"
set recolor-keephue
set completion-bg "#f5f5f5"
set completion-fg "#303030"
set completion-group-bg "#f5f5f5"
set completion-group-fg "#303030"
set completion-highlight-bg "#f5f5f5"
set completion-highlight-fg "#303030"
set recolor-lightcolor "#f5f5f5"
set recolor-darkcolor "#303030"
set default-bg "#f5f5f5"
set inputbar-bg "#d0d0d0"
set inputbar-fg "#303030"
set notification-bg "#d0d0d0"
set notification-fg "#303030"
set notification-error-bg "#ac4142"
set notification-error-fg "#303030"
set notification-warning-bg "#ac4142"
set notification-warning-fg "#303030"
set statusbar-bg "#d0d0d0"
set statusbar-fg "#303030"
set index-bg "#d0d0d0"
set index-fg "#303030"
set index-active-bg "#151515"
set index-active-fg "#f5f5f5"
set render-loading-bg "#f5f5f5"
set render-loading-fg "#303030"
set highlight-color "#b4d36f"
set highlight-active-color "#8fd7f5"
set window-title-home-tilde true
set statusbar-basename true
set selection-clipboard clipboard
set scroll-page-aware true
set statusbar-home-tilde true
set statusbar-h-padding 10
set statusbar-v-padding 10
