# :.config/zathura/zathurarc

set synctex true
set selection-notification "true"
set guioptions ""
set adjust-open "best-fit"
set recolor "true"
set recolor-keephue
set completion-bg "#121212"
set completion-fg "#bebebe"
set completion-group-bg "#121212"
set completion-group-fg "#bebebe"
set completion-highlight-bg "#121212"
set completion-highlight-fg "#bebebe"
set recolor-lightcolor "#121212"
set recolor-darkcolor "#bebebe"
set default-bg "#121212"
set inputbar-bg "#353535"
set inputbar-fg "#bebebe"
set notification-bg "#353535"
set notification-fg "#bebebe"
set notification-error-bg "#637a8a"
set notification-error-fg "#bebebe"
set notification-warning-bg "#637a8a"
set notification-warning-fg "#bebebe"
set statusbar-bg "#353535"
set statusbar-fg "#bebebe"
set index-bg "#353535"
set index-fg "#bebebe"
set index-active-bg "#949494"
set index-active-fg "#121212"
set render-loading-bg "#121212"
set render-loading-fg "#bebebe"
set highlight-color "#8d7667"
set highlight-active-color "#6c574c"
set window-title-home-tilde true
set statusbar-basename true
set selection-clipboard clipboard
set scroll-page-aware true
set statusbar-home-tilde true
set statusbar-h-padding 10
set statusbar-v-padding 10
