# :.config/zathura/zathurarc
set font "Source Serif Pro 13"
set synctex true
set selection-notification "true"
set guioptions ""
set adjust-open "best-fit"
set scroll-page-aware "true"
set scroll-full-overlap 0.01
set scroll-step 100
set recolor "true"
set recolor-keephue
set completion-bg "#e9e5e2"
set completion-fg "#161e29"
set completion-group-bg "#e9e5e2"
set completion-group-fg "#161e29"
set completion-highlight-bg "#e9e5e2"
set completion-highlight-fg "#161e29"
set recolor-lightcolor "#e9e5e2"
set recolor-darkcolor "#161e29"
set default-bg "#e9e5e2"
set inputbar-bg "#c8beb7"
set inputbar-fg "#161e29"
set notification-bg "#c8beb7"
set notification-fg "#161e29"
set notification-error-bg "#630e49"
set notification-error-fg "#161e29"
set notification-warning-bg "#630e49"
set notification-warning-fg "#161e29"
set statusbar-bg "#c8beb7"
set statusbar-fg "#161e29"
set index-bg "#c8beb7"
set index-fg "#161e29"
set index-active-bg "#374250"
set index-active-fg "#e9e5e2"
set render-loading-bg "#e9e5e2"
set render-loading-fg "#161e29"
set highlight-color "#844242"
set highlight-active-color "#372969"
set window-title-home-tilde true
set statusbar-basename true
set selection-clipboard clipboard
set scroll-page-aware true
set statusbar-home-tilde true
set statusbar-h-padding 10
set statusbar-v-padding 10
