# :.config/zathura/zathurarc

set synctex true
set selection-notification "true"
set guioptions ""
set adjust-open "best-fit"
set recolor "true"
set recolor-keephue
set completion-bg "#ede6e3"
set completion-fg "#685c56"
set completion-group-bg "#ede6e3"
set completion-group-fg "#685c56"
set completion-highlight-bg "#ede6e3"
set completion-highlight-fg "#685c56"
set recolor-lightcolor "#ede6e3"
set recolor-darkcolor "#685c56"
set default-bg "#ede6e3"
set inputbar-bg "#b8b2b0"
set inputbar-fg "#685c56"
set notification-bg "#b8b2b0"
set notification-fg "#685c56"
set notification-error-bg "#3a3a3a"
set notification-error-fg "#685c56"
set notification-warning-bg "#3a3a3a"
set notification-warning-fg "#685c56"
set statusbar-bg "#b8b2b0"
set statusbar-fg "#685c56"
set index-bg "#b8b2b0"
set index-fg "#685c56"
set index-active-bg "#3b3531"
set index-active-fg "#ede6e3"
set render-loading-bg "#ede6e3"
set render-loading-fg "#685c56"
set highlight-color "#485965"
set highlight-active-color "#676a5d"
set window-title-home-tilde true
set statusbar-basename true
set selection-clipboard clipboard
set scroll-page-aware true
set statusbar-home-tilde true
set statusbar-h-padding 10
set statusbar-v-padding 10
