# :.config/khal/config
[calendars]

[[personal]]
path = ~/.local/share/vdirsyncer/calendars/personal
type = calendar
color = dark red

[[uni]]
path = ~/.local/share/vdirsyncer/calendars/university-of-bristol-personal-timetable-ju20390bristolacuk-1
type = calendar
color = dark magenta

[default]
highlight_event_days = True
show_all_days = False
default_calendar = personal

[highlight_days]
method = fg
multiple = dark blue

[locale]
local_timezone= Europe/London
default_timezone= Europe/London
timeformat = %H:%M
dateformat = %Y-%m-%d
longdateformat = %Y-%m-%d
datetimeformat = %Y-%m-%d %H:%M
longdatetimeformat = %Y-%m-%d %H:%M

[view]
frame = False
event_view_always_visible = False
agenda_event_format = 﨟{calendar-color}{bold}{cancelled}{start-end-time-style}   {title}{repeat-symbol}{alarm-symbol}  車{location}{reset}
event_format = {calendar-color}{cancelled}{start}-{end} {title}{repeat-symbol}{alarm-symbol}{description-separator}{description}{reset}
