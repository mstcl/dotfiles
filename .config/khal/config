# :.config/khal/config
[calendars]

[[personal]]
path = ~/.local/share/vdirsyncer/calendars/personal
type = calendar
color = dark green

[[birthdays]]
path = ~/.local/share/vdirsyncer/calendars/contact_birthdays
type = calendar
color = dark red

[default]
highlight_event_days = True
show_all_days = False
default_calendar = personal

[highlight_days]
method = fg
multiple = dark blue

[locale]
local_timezone= Europe/London
default_timezone= Europe/London
timeformat = %H:%M
dateformat = %Y-%m-%d
longdateformat = %Y-%m-%d
datetimeformat = %Y-%m-%d %H:%M
longdatetimeformat = %Y-%m-%d %H:%M

[view]
frame = False
