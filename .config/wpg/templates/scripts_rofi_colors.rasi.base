/* colors */

* {{
    al: {color8};
    bg: {color0};
    bg1: {color1};
    bg2: {color2};
    bg3: {color3};
    bg4: {color4};
    bg5: {color5};
    bg6: {color6};
    fg: {color7};
    fg2: {color15};
    hi-bold: bold {color1};
    font: "{font0} {font-size}";
    font-icon: "{font0} {font-size-icon}";
    icon-theme: "{icons}";
    show-icons: {show-icons};
}}
