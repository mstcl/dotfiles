#### GENERAL ####
set $mod Mod4
set $alt Mod1
font pango:Helvetica Neue 12
gaps outer 0
gaps inner 10
for_window [class="^.*"] border pixel 0
workspace_auto_back_and_forth yes

#### STARTUP ####
exec --no-startup-id bash $HOME/.config/wpg/wp_init.sh &
exec --no-startup-id xrdb $HOME/.Xresources &
exec --no-startup-id xss-lock --transfer-sleep-lock -- sh ~/scripts/i3lock/lockerfancy
exec --no-startup-id picom &
exec --no-startup-id bash $HOME/.fehbg &
exec --no-startup-id redshift &
exec --no-startup-id bash $HOME/scripts/polybar/launch.sh &
exec --no-startup-id xmodmap $HOME/dotfiles/.xmodmap &
exec --no-startup-id unclutter &
exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec --no-startup-id $HOME/.local/bin/i3-notifier &
exec --no-startup-id $HOME/scripts/bin/mkdocs-init &

######### COLORS ##########
set_from_resource $fg i3wm.color7 #f0f0f0
set_from_resource $bg i3wm.color0 #f0f0f0
set_from_resource $c1 i3wm.color2 #f0f0f0
# class                 border  backgr. text indicator child_border
client.focused          $bg     $bg     $fg  $bg       $c1
client.focused_inactive $bg     $bg     $fg  $bg       $bg
client.unfocused        $bg     $bg     $fg  $bg       $bg
client.urgent           $bg     $bg     $fg  $bg       $bg
client.placeholder      $bg     $bg     $fg  $bg       $bg
client.background       $bg

#### BAR ###

bar {
    status_command i3status --config ~/.config/i3status/config
    workspace_buttons no
    tray_padding 2
    mode hide
    hidden_state hide
    modifier $mod
    binding_mode_indicator no
    separator_symbol "|"
    font pango:JetBrainsMono Nerd Font Mono 10
    colors {
        background $bg
        statusline $fg
}}

#### KEYBINDINGS ####
floating_modifier $mod

### SCRATCHPAD ###
bindsym $mod+minus move scratchpad
bindsym $mod+plus scratchpad show

### FOCUSING ###
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

### LAYOUTS ###
bindsym $mod+v split v
bindsym $mod+z split h
bindsym $mod+f fullscreen toggle
popup_during_fullscreen smart
bindsym $mod+Shift+e layout toggle split
bindsym $mod+x focus mode_toggle
bindsym $mod+Shift+space floating toggle
bindsym $mod+o sticky toggle
bindsym $mod+button3 floating toggle
bindsym --whole-window $mod+button2 kill
bindsym $mod+Shift+q	kill
focus_on_window_activation focus

### PROGRAMS ###
bindsym $mod+b	exec --no-startup-id brave
bindsym $mod+p exec --no-startup-id bash ~/scripts/polybar/bar/scripts/powermenu.sh &
bindsym $mod+Shift+p exec --no-startup-id bash ~/scripts/polybar/launch.sh &
bindsym $mod+Return	exec --no-startup-id kitty -e
bindsym $mod+c exec --no-startup-id qalculate-gtk
bindsym $mod+space exec --no-startup-id bash ~/scripts/polybar/bar/scripts/launcher.sh
bindsym $mod+e  exec --no-startup-id pcmanfm
bindsym $mod+period exec --no-startup-id bash ~/scripts/rofi/emojipick/emojipick
bindsym $mod+Tab exec --no-startup-id bash ~/scripts/rofi/i3-resurrect
bindsym $mod+n exec --no-startup-id dbus-send --session --print-reply --dest=org.freedesktop.Notifications /org/freedesktop/Notifications org.freedesktop.Notifications.ShowNotifications &
bindsym $mod+g exec bash ~/scripts/other/text-scratchpad
bindsym $mod+Shift+Return exec kitty -e -T floatingKitty
bindsym $alt+b [class="Brave"] focus
bindsym $alt+Tab exec rofi -show window
bindsym $alt+v [class="Easyeffects"] focus
bindsym $alt+t [class="kitty"] focus
bindsym $alt+p exec maim ~/screenshots/$(date +%s).png && notify-send "screenshot saved!"
bindsym $alt+Shift+p exec --no-startup-id maim -s | xclip -selection clipboard -t image/png
bindsym $alt+slash exec --no-startup-id sp play
bindsym $alt+s [class="Spotify"] focus
bindsym $alt+d [class="discord"] focus
bindsym $alt+period exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10%
bindsym $alt+comma exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10%
bindsym $alt+m exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym $alt+n exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle

### WINDOW RULES ###
for_window [class="steam_app_1182480"] floating enable
for_window [class="^kitty$" title="^textScratchpad$"] floating enable
for_window [class="Pavucontrol"] floating enable
for_window [class="Pavucontrol"] resize set 940 680
for_window [class="Pcmanfm"] floating enable
for_window [class="Pcmanfm"] resize set 940 680
for_window [class="Qalculate-gtk"] floating enable
for_window [class="Qalculate-gtk"] resize set 640 480
for_window [class="^kitty$" title="^floatingKitty$"] floating enable;
for_window [class="^kitty$" title="^floatingKitty$"] resize set 640 480; move absolute position center
for_window [class="Wpg"] floating enable
for_window [class="Wpg"] resize set 640 480

### WORKSPACE ###
bindsym $mod+1 workspace 1
bindsym $mod+2 workspace 2
bindsym $mod+3 workspace 3
bindsym $mod+4 workspace 4
bindsym $mod+5 workspace 5
bindsym $mod+6 workspace 6
bindsym $mod+7 workspace 7
bindsym $mod+8 workspace 8
bindsym $mod+9 workspace 9
bindsym $mod+0 workspace 10
bindsym $mod+Left workspace prev
bindsym $mod+Right workspace next
bindsym $mod+Shift+1 move container to workspace 1
bindsym $mod+Shift+2 move container to workspace 2
bindsym $mod+Shift+3 move container to workspace 3
bindsym $mod+Shift+4 move container to workspace 4
bindsym $mod+Shift+5 move container to workspace 5
bindsym $mod+Shift+6 move container to workspace 6
bindsym $mod+Shift+7 move container to workspace 7
bindsym $mod+Shift+8 move container to workspace 8
bindsym $mod+Shift+9 move container to workspace 9
bindsym $mod+Shift+0 move container to workspace 10
bindsym $mod+Shift+Left move container to workspace prev
bindsym $mod+Shift+Right move container to workspace next

### I3 SETTINGS ###
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+x exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -b 'Yes, exit i3' 'i3-msg exit'"

#### MODES ####
mode "resize" {
        bindsym j resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym l resize shrink height 10 px or 10 ppt
        bindsym semicolon resize grow width 10 px or 10 ppt
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

set $mode_system System (l) lock, (e) logout, (s) suspend, (r) reboot, (Shift+s) shutdown
mode "$mode_system" {
    bindsym l exec --no-startup-id loginctl lock-session, mode "default"
    bindsym e exec --no-startup-id i3-msg exit, mode "default"
    bindsym s exec --no-startup-id loginctl lock-session && systemctl suspend, mode "default"
    bindsym r exec --no-startup-id systemctl reboot, mode "default"
	bindsym Shift+s exec --no-startup-id systemctl poweroff -i, mode "default"
	bindsym Return mode "default"
    bindsym Escape mode "default"
}
#bindsym $mod+Shift+p mode a$mode_system"

