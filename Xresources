*color8:  #353535
*.color9: #bc8778
*color9:  #bc8778
*.color10: #a0ac82
*color10:  #a0ac82
*.color11: #c3ae8b
*color11:  #c3ae8b
*.color12: #8f9cae
*color12:  #8f9cae
*.color13: #a392a5
