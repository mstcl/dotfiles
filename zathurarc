set notification-error-fg "#f6f6f6"
set notification-warning-bg "#b67262"
set notification-warning-fg "#f6f6f6"
set statusbar-bg "#353535"
set statusbar-fg "#f6f6f6"
set index-bg "#353535"
set index-fg "#f6f6f6"
set index-active-bg "#e3e3e3"
