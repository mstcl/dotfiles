# :.config/zathura/zathurarc

set selection-notifiation "true"
set guioptions ""
set adjust-open "best-fit"
set recolor "true"
set recolor-keephue
set completion-bg "#101010"
set completion-fg "#f6f6f6"
set completion-group-bg "#101010"
set completion-group-fg "#f6f6f6"
set completion-highlight-bg "#101010"
set completion-highlight-fg "#f6f6f6"
