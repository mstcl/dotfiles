! X colors.
! Generated by 'wal'
*foreground:        #dbc0aa
*background:        #0c0a07
*.foreground:       #dbc0aa
*.background:       #0c0a07
emacs*foreground:   #dbc0aa
emacs*background:   #0c0a07
URxvt*foreground:   #dbc0aa
XTerm*foreground:   #dbc0aa
UXTerm*foreground:  #dbc0aa
URxvt*background:   [100]#0c0a07
XTerm*background:   #0c0a07
UXTerm*background:  #0c0a07
URxvt*cursorColor:  #dbc0aa
XTerm*cursorColor:  #dbc0aa
UXTerm*cursorColor: #dbc0aa
URxvt*borderColor:  [100]#0c0a07

! Colors 0-15.
*.color0: #0c0a07
*color0:  #0c0a07
*.color1: #8D3315
*color1:  #8D3315
*.color2: #A73817
*color2:  #A73817
*.color3: #A25528
*color3:  #A25528
*.color4: #C57239
*color4:  #C57239
*.color5: #B27648
*color5:  #B27648
*.color6: #BB875E
*color6:  #BB875E
*.color7: #dbc0aa
*color7:  #dbc0aa
*.color8: #998676
*color8:  #998676
*.color9: #8D3315
*color9:  #8D3315
*.color10: #A73817
*color10:  #A73817
*.color11: #A25528
*color11:  #A25528
*.color12: #C57239
*color12:  #C57239
*.color13: #B27648
*color13:  #B27648
*.color14: #BB875E
*color14:  #BB875E
*.color15: #dbc0aa
*color15:  #dbc0aa

! Black color that will not be affected by bold highlighting.
*.color66: #0c0a07
*color66:  #0c0a07

! Xclock colors.
XClock*foreground: #dbc0aa
XClock*background: #0c0a07
XClock*majorColor:  rgba:db/c0/aa/ff
XClock*minorColor:  rgba:db/c0/aa/ff
XClock*hourColor:   rgba:db/c0/aa/ff
XClock*minuteColor: rgba:db/c0/aa/ff
XClock*secondColor: rgba:db/c0/aa/ff

! Set depth to make transparency work.
URxvt*depth: 32

Xft.antialias: 1
Xft.hinting: 1
Xft.autohint: 0
Xft.rgba: rgb
Xft.hintstyle: hintslight
Xft.lcdfilter: lcdlight

Xcursor.theme: Bibata-Modern-Classic
