set guioptions ""
set adjust-open "best-fit"
set recolor "true"
set recolor-keephue
set completion-bg "#232326"
set completion-fg "#c1c1c1"
set completion-group-bg "#232326"
set completion-group-fg "#eceee3"
set completion-highlight-bg "#c1c1c1"
set completion-highlight-fg "#232326"
set recolor-lightcolor "#232326"
set recolor-darkcolor "#c1c1c1"
set default-bg "#232326"
set inputbar-bg "#232326"
set inputbar-fg "#c1c1c1"
set notification-bg "#232326"
set notification-fg "#c1c1c1"
set notification-error-bg "#5f8787"
set notification-error-fg "#c1c1c1"
set notification-warning-bg "#5f8787"
set notification-warning-fg "#c1c1c1"
set statusbar-bg "#232326"
set statusbar-fg "#c1c1c1"
set index-bg "#232326"
set index-fg "#c1c1c1"
set index-active-bg "#c1c1c1"
set index-active-fg "#232326"
set render-loading-bg "#232326"
set render-loading-fg "#c1c1c1"
set window-title-home-tilde true
set statusbar-basename true
set selection-clipboard clipboard
